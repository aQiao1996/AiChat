# Docker Compose 基础配置
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=ai_chat_prod
MYSQL_PORT=3307
BACKEND_PORT=3001
FRONTEND_PORT=8080

# 后端配置
JWT_SECRET=change_me_at_least_32_characters_long
RUN_MIGRATIONS=true

# reCAPTCHA 配置
RECAPTCHA_SITE_KEY=
VITE_APP_GOOGLE_RECAPTCHA_SITE_KEY=

# AI 配置
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=gpt-5.4
OPENAI_COMPATIBLE_REASONING_EFFORT=low
DATABASE_DASHSCOPE_API_KEY=
DATABASE_DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 前端配置
VITE_APP_BASE_URL=/api
